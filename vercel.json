{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://pivota-agent-production.up.railway.app/v1/:path*"
    },
    {
      "source": "/health",
      "destination": "https://pivota-agent-production.up.railway.app/health"
    },
    {
      "source": "/healthz",
      "destination": "https://pivota-agent-production.up.railway.app/healthz"
    },
    {
      "source": "/metrics",
      "destination": "https://pivota-agent-production.up.railway.app/metrics"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
